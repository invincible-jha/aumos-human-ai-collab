# AumOS Human-AI Collaboration — Environment Variables
# Copy to .env and fill in values for local development.
# NEVER commit .env to version control.

# ── Database ───────────────────────────────────────────────────────────────
AUMOS_HUMAN_AI_DATABASE__URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_human_ai_collab
AUMOS_HUMAN_AI_DATABASE__POOL_SIZE=10
AUMOS_HUMAN_AI_DATABASE__MAX_OVERFLOW=20

# ── Kafka ──────────────────────────────────────────────────────────────────
AUMOS_HUMAN_AI_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
AUMOS_HUMAN_AI_KAFKA__CONSUMER_GROUP=aumos-human-ai-collab

# ── Service ────────────────────────────────────────────────────────────────
AUMOS_HUMAN_AI_ENVIRONMENT=development
AUMOS_HUMAN_AI_LOG_LEVEL=INFO

# ── Confidence Routing ─────────────────────────────────────────────────────
AUMOS_HUMAN_AI_AI_CONFIDENCE_THRESHOLD=0.85
AUMOS_HUMAN_AI_HYBRID_CONFIDENCE_LOWER=0.65

# ── HITL Review Queue ──────────────────────────────────────────────────────
AUMOS_HUMAN_AI_HITL_REVIEW_TIMEOUT_HOURS=24
AUMOS_HUMAN_AI_HITL_MAX_CONCURRENT_REVIEWS=50
AUMOS_HUMAN_AI_REDIS_URL=redis://localhost:6379/0

# ── Compliance Gate Cache ──────────────────────────────────────────────────
AUMOS_HUMAN_AI_COMPLIANCE_CACHE_TTL_SECONDS=300

# ── Attribution ────────────────────────────────────────────────────────────
AUMOS_HUMAN_AI_ATTRIBUTION_REPORT_DAYS=30

# ── Feedback Calibration ───────────────────────────────────────────────────
AUMOS_HUMAN_AI_FEEDBACK_CALIBRATION_MIN_SAMPLES=10
AUMOS_HUMAN_AI_FEEDBACK_DECAY_FACTOR=0.9

# ── Upstream Services ──────────────────────────────────────────────────────
AUMOS_HUMAN_AI_GOVERNANCE_ENGINE_URL=http://localhost:8016
AUMOS_HUMAN_AI_MODEL_REGISTRY_URL=http://localhost:8004

# ── HTTP Client ────────────────────────────────────────────────────────────
AUMOS_HUMAN_AI_HTTP_TIMEOUT=30.0
AUMOS_HUMAN_AI_HTTP_MAX_RETRIES=3
